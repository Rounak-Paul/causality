build/
bin/
lib/

# CMake in-source build artifacts (recursive — catches any subdirectory)
**/CMakeCache.txt
**/CMakeFiles/
**/cmake_install.cmake
**/cmake_uninstall.cmake

# Only ignore the root Makefile and subdirectory Makefiles generated by CMake.
# (The build/ dir is already ignored above.)
Makefile
causality/Makefile
sandbox/Makefile
vendors/**/Makefile